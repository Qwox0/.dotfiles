[user]
	name = Qwox
	email = qwox@qwox.com
[credential]
	helper = store
[init]
	defaultBranch = master
[http]
    proxy = http://172.16.7.13:8080
[https]
	proxy = http://172.16.7.13:8080
[alias]
    tree = tree-self --all
    tree-self = log --graph --decorate --oneline --format=format:'%C(auto)%h%d %C(white)%s %C(dim white)- %an %C(green)(%ar)%C(reset)'
    clone-as-worktree = "!git-clone-as-worktree.sh"
